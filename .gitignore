# Rust build output (workspace at repo root)
/target
**/*.rs.bk

# glass-fixture-egui is excluded from the workspace (heavy egui deps), so it builds into its
# own target/ (the first-drive tutorial has the agent build it). Its Cargo.lock is tracked.
/crates/glass-fixture-egui/target/

# glass working dir created in target projects
.glass/

# Profiling output (cargo-flamegraph / perf write these to the CWD)
flamegraph.svg
perf.data
perf.data.old

# Coverage output (cargo-llvm-cov)
*.profraw

# Editor / OS cruft
*.swp
.DS_Store
.idea/

# Pulled-back artifacts from scripts/test-windows.sh on-box runs
/.windows-artifacts/

# Fixture cruft
**/__pycache__/
